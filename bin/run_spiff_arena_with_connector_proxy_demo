#!/usr/bin/env bash

set -o errexit -o nounset -o pipefail

workspace_root="${SPIFF_ARENA_WORKSPACE_ROOT:-$HOME}"

function add_mise_node_to_path() {
  local node_bin_dir

  if command -v npm >/dev/null 2>&1; then
    return
  fi

  if command -v mise >/dev/null 2>&1; then
    node_bin_dir="$(mise which node 2>/dev/null || true)"
    if [ -n "$node_bin_dir" ]; then
      node_bin_dir="$(dirname "$node_bin_dir")"
      export PATH="$node_bin_dir:$PATH"
    fi
  fi

  if ! command -v npm >/dev/null 2>&1 && [ -x "$HOME/.local/share/mise/installs/node/lts/bin/npm" ]; then
    export PATH="$HOME/.local/share/mise/installs/node/lts/bin:$PATH"
  fi
}

function require_command() {
  local command_name="$1"
  if ! command -v "$command_name" >/dev/null 2>&1; then
    echo >&2 "$command_name is not installed or not on PATH"
    exit 1
  fi
}

add_mise_node_to_path
require_command overmind
require_command tmux
require_command npm
require_command poetry

if [ -n "${SPIFF_ARENA_ROOT:-}" ]; then
  spiff_arena_root="$SPIFF_ARENA_ROOT"
elif [ -d "$workspace_root/spiffworkflow-backend" ] && [ -d "$workspace_root/spiffworkflow-frontend" ]; then
  spiff_arena_root="$workspace_root"
else
  spiff_arena_root="$workspace_root/spiff-arena"
fi

procfile="${SPIFF_ARENA_PROCFILE:-$spiff_arena_root/procfiles/spiff-arena-connector-proxy-demo.Procfile}"
connector_proxy_demo_root="$spiff_arena_root/connector-proxy-demo"
spiffworkflow_proxy_root="${SPIFFWORKFLOW_PROXY_ROOT:-$HOME/spiffworkflow-proxy}"

for required_dir in \
  "$spiff_arena_root/spiffworkflow-backend" \
  "$spiff_arena_root/spiffworkflow-frontend" \
  "$connector_proxy_demo_root" \
  "$spiffworkflow_proxy_root"
do
  if [ ! -d "$required_dir" ]; then
    echo >&2 "missing required directory: $required_dir"
    exit 1
  fi
done

if [ ! -f "$procfile" ]; then
  echo >&2 "missing Procfile: $procfile"
  exit 1
fi

export SPIFF_ARENA_ROOT="$spiff_arena_root"
export SPIFFWORKFLOW_PROXY_ROOT="$spiffworkflow_proxy_root"
export __VITE_ADDITIONAL_SERVER_ALLOWED_HOSTS="${SPIFF_ARENA_FRONTEND_ALLOWED_HOST:-$(hostname -s)}"

cd "$spiff_arena_root"

function ensure_postgres_database() {
  local database_uri="$1"
  local database_name

  echo "checking local Postgres database from SPIFFWORKFLOW_BACKEND_DATABASE_URI"
  case "$database_uri" in
    postgresql:///*)
      database_name="${database_uri#postgresql:///}"
      database_name="${database_name%%\?*}"
      ;;
    postgres:///*)
      database_name="${database_uri#postgres:///}"
      database_name="${database_name%%\?*}"
      ;;
    *)
      return
      ;;
  esac

  if [ -z "$database_name" ]; then
    return
  fi

  require_command psql
  require_command createdb

  if ! psql -d "$database_name" -c "select 1" >/dev/null 2>&1; then
    echo "creating local Postgres database: $database_name"
    createdb "$database_name"
  else
    echo "local Postgres database exists: $database_name"
  fi
}

function ensure_frontend_dependencies() {
  local frontend_dir="$1"

  if [ ! -x "$frontend_dir/node_modules/.bin/vite" ]; then
    echo "installing frontend dependencies with npm ci"
    (cd "$frontend_dir" && npm ci)
  else
    echo "frontend dependencies already installed"
  fi
}

function ensure_connector_proxy_demo_dependencies() {
  local connector_proxy_dir="$1"
  local proxy_dir="$2"

  echo "installing connector-proxy-demo dependencies with Poetry"
  (
    cd "$connector_proxy_dir"
    poetry install
    poetry run pip install -e "$proxy_dir"
  )
}

subcommand="${1:-start}"
if [ "$#" -gt 0 ]; then
  shift
fi

if [ "$subcommand" = "stop" ]; then
  exec overmind quit "$@"
elif [ "$subcommand" = "status" ]; then
  exec overmind status "$@"
elif [ "$subcommand" = "kill" ]; then
  exec overmind kill "$@"
elif [ "$subcommand" != "start" ]; then
  set -- "$subcommand" "$@"
fi

backend_dir="$spiff_arena_root/spiffworkflow-backend"
hot_spiff_env="${SPIFF_ARENA_HOT_SPIFF_ENV:-$HOME/infra_provisioned_files/hot_spiff_env}"
if [ ! -f "$hot_spiff_env" ]; then
  echo >&2 "missing hot Spiff env: $hot_spiff_env"
  exit 1
fi

echo "sourcing hot Spiff env: $hot_spiff_env"
# shellcheck disable=SC1091
source "$hot_spiff_env"

if [ "${SPIFFWORKFLOW_BACKEND_DATABASE_TYPE:-}" = "postgres" ]; then
  ensure_postgres_database "${SPIFFWORKFLOW_BACKEND_DATABASE_URI:-}"
fi
ensure_frontend_dependencies "$spiff_arena_root/spiffworkflow-frontend"
ensure_connector_proxy_demo_dependencies "$connector_proxy_demo_root" "$spiffworkflow_proxy_root"

echo "running backend database migrations"
(
  cd "$backend_dir"
  SPIFFWORKFLOW_BACKEND_RUN_BACKGROUND_SCHEDULER_IN_CREATE_APP=false uv run flask db upgrade
)
echo "backend database migrations complete"

socket_path="$spiff_arena_root/.overmind.sock"
if [ "$subcommand" = "start" ] && [ -S "$socket_path" ] && ! overmind status >/dev/null 2>&1; then
  echo "removing stale overmind socket: $socket_path"
  rm -f "$socket_path"
fi

if [ "$subcommand" = "start" ] && overmind status >/dev/null 2>&1; then
  echo "overmind is already running; showing status"
  exec overmind status
fi

echo "starting Spiff Arena with connector-proxy-demo overmind Procfile"
exec overmind start -f "$procfile" "$@"
