#!/usr/bin/env bash

function error_handler() {
  >&2 echo "Exited with BAD EXIT CODE '${2}' in ${0} script at line: ${1}."
  exit "$2"
}
trap 'error_handler ${LINENO} $?' ERR
set -o errtrace -o errexit -o nounset -o pipefail

port="${CONNECTOR_PROXY_ASYNC_HTTP_PORT:-}"
if [[ -z "$port" ]]; then
  port=7004
fi

workers=3

# THIS MUST BE THE LAST COMMAND!
# Dependencies are already installed into the image virtualenv during build,
# so avoid invoking pip again at runtime.
exec granian --host "0.0.0.0" --port "$port" --workers "$workers" --interface asgi main:app
