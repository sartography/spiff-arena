backend: cd "${SPIFF_ARENA_ROOT:?}/spiffworkflow-backend" && bash -lc 'source "${SPIFF_ARENA_HOT_SPIFF_ENV:-$HOME/infra_provisioned_files/hot_spiff_env}" && export SPIFFWORKFLOW_BACKEND_CONNECTOR_PROXY_URL=http://localhost:7004 SPIFFWORKFLOW_BACKEND_CELERY_ENABLED=true SPIFFWORKFLOW_BACKEND_BACKGROUND_SCHEDULER_ENABLED=true SPIFFWORKFLOW_BACKEND_RUN_BACKGROUND_SCHEDULER_IN_CREATE_APP=true SPIFFWORKFLOW_BACKEND_URL=http://localhost:7000 && ./bin/run_server_locally'
frontend: cd "${SPIFF_ARENA_ROOT:?}/spiffworkflow-frontend" && npm start -- --host 0.0.0.0 --port 7001 --force
celery-worker: cd "${SPIFF_ARENA_ROOT:?}/spiffworkflow-backend" && bash -lc 'source "${SPIFF_ARENA_HOT_SPIFF_ENV:-$HOME/infra_provisioned_files/hot_spiff_env}" && export SPIFFWORKFLOW_BACKEND_CONNECTOR_PROXY_URL=http://localhost:7004 SPIFFWORKFLOW_BACKEND_CELERY_ENABLED=true SPIFFWORKFLOW_BACKEND_BACKGROUND_SCHEDULER_ENABLED=true SPIFFWORKFLOW_BACKEND_RUN_BACKGROUND_SCHEDULER_IN_CREATE_APP=true SPIFFWORKFLOW_BACKEND_URL=http://localhost:7000 && ./bin/run_server_locally celery_worker'
connector-proxy-demo: cd "${SPIFF_ARENA_ROOT:?}/connector-proxy-demo" && CONNECTOR_PROXY_PORT=7004 ./bin/run_server_locally
