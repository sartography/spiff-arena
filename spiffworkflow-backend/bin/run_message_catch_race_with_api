#!/usr/bin/env bash

function error_handler() {
  echo >&2 "Exited with BAD EXIT CODE '${2}' in ${0} script at line: ${1}."
  exit "$2"
}
trap 'error_handler ${LINENO} $?' ERR
set -o errtrace -o errexit -o nounset -o pipefail

script_dir="$(
  cd -- "$(dirname "$0")" >/dev/null 2>&1
  pwd -P
)"

if [[ -z "${BACKEND_BASE_URL:-}" ]]; then
  export BACKEND_BASE_URL=http://localhost:7000
fi

process_model_identifier="${1:-admin/message-catch-race}"
message_name="${2:-race_callback}"
race_id="${3:-race-$(date +%s)-$$}"
message_instance_uuid="${4:-$(uuidgen 2>/dev/null || uv run python -c 'import uuid; print(uuid.uuid4())')}"
username="${5:-admin}"
password="${6:-admin}"
realm_name="${7:-spiffworkflow}"

if [[ -z "${process_model_identifier}" ]]; then
  echo >&2 "usage: $(basename "$0") [process_model_identifier: OPTIONAL] [message_name: OPTIONAL] [race_id: OPTIONAL] [message_instance_uuid: OPTIONAL] [username: OPTIONAL] [password: OPTIONAL] [realm_name: OPTIONAL]"
  exit 1
fi

modified_process_model_identifier=$(tr '/' ':' <<<"$process_model_identifier")
process_group_identifier="${process_model_identifier%/*}"
primary_file_name="message-catch-race.bpmn"
primary_process_id="Process_message_catch_race_9k4v7m"

if [[ "${process_group_identifier}" == "${process_model_identifier}" ]]; then
  echo >&2 "ERROR: process_model_identifier must include a process group, for example admin/message-catch-race"
  exit 1
fi

modified_process_group_identifier=$(tr '/' ':' <<<"$process_group_identifier")

tmp_bpmn_file=""
function cleanup() {
  if [[ -n "${tmp_bpmn_file}" && -f "${tmp_bpmn_file}" ]]; then
    rm -f "${tmp_bpmn_file}"
  fi
}
trap cleanup EXIT

function write_embedded_bpmn() {
  local output_file="$1"
  cat >"$output_file" <<'BPMN'
<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:spiffworkflow="http://spiffworkflow.org/bpmn/schema/1.0/core" id="Definitions_message_catch_race" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="3.0.0-dev">
  <bpmn:collaboration id="Collaboration_message_catch_race">
    <bpmn:participant id="Participant_message_catch_race" name="Message Catch Race" processRef="Process_message_catch_race_9k4v7m" />
    <bpmn:correlationKey name="MainCorrelationKey">
      <bpmn:correlationPropertyRef>race_id</bpmn:correlationPropertyRef>
    </bpmn:correlationKey>
  </bpmn:collaboration>
  <bpmn:message id="Message_race_callback" name="race_callback" />
  <bpmn:correlationProperty id="race_id" name="race_id">
    <bpmn:correlationPropertyRetrievalExpression messageRef="Message_race_callback">
      <bpmn:formalExpression>race_id</bpmn:formalExpression>
    </bpmn:correlationPropertyRetrievalExpression>
  </bpmn:correlationProperty>
  <bpmn:process id="Process_message_catch_race_9k4v7m" name="Message Catch Race" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_start_to_sleep</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_start_to_sleep" sourceRef="StartEvent_1" targetRef="Task_wait_for_callback" />
    <bpmn:manualTask id="Task_wait_for_callback" name="Wait for callback">
      <bpmn:incoming>Flow_start_to_sleep</bpmn:incoming>
      <bpmn:outgoing>Flow_sleep_to_receive</bpmn:outgoing>
      <bpmn:extensionElements>
        <spiffworkflow:instructionsForEndUser>Hold this task open while the callback is sent.</spiffworkflow:instructionsForEndUser>
      </bpmn:extensionElements>
    </bpmn:manualTask>
    <bpmn:sequenceFlow id="Flow_sleep_to_receive" sourceRef="Task_wait_for_callback" targetRef="Event_receive_callback" />
    <bpmn:intermediateCatchEvent id="Event_receive_callback" name="Receive callback">
      <bpmn:incoming>Flow_sleep_to_receive</bpmn:incoming>
      <bpmn:outgoing>Flow_receive_to_end</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_receive_callback" messageRef="Message_race_callback" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_receive_to_end" sourceRef="Event_receive_callback" targetRef="Event_end" />
    <bpmn:endEvent id="Event_end">
      <bpmn:incoming>Flow_receive_to_end</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_message_catch_race">
    <bpmndi:BPMNPlane id="BPMNPlane_message_catch_race" bpmnElement="Collaboration_message_catch_race">
      <bpmndi:BPMNShape id="Participant_message_catch_race_di" bpmnElement="Participant_message_catch_race" isHorizontal="true">
        <dc:Bounds x="100" y="80" width="760" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="160" y="149" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_wait_for_callback_di" bpmnElement="Task_wait_for_callback">
        <dc:Bounds x="250" y="127" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_receive_callback_di" bpmnElement="Event_receive_callback">
        <dc:Bounds x="450" y="149" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_end_di" bpmnElement="Event_end">
        <dc:Bounds x="580" y="149" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_start_to_sleep_di" bpmnElement="Flow_start_to_sleep">
        <di:waypoint x="196" y="167" />
        <di:waypoint x="250" y="167" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_sleep_to_receive_di" bpmnElement="Flow_sleep_to_receive">
        <di:waypoint x="370" y="167" />
        <di:waypoint x="450" y="167" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_receive_to_end_di" bpmnElement="Flow_receive_to_end">
        <di:waypoint x="486" y="167" />
        <di:waypoint x="580" y="167" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
BPMN
}

function curl_with_status() {
  local method="$1"
  local url="$2"
  local token="$3"
  shift 3
  curl --silent --show-error -X "$method" "$url" -H "Authorization: Bearer ${token}" "$@" --write-out $'\n%{http_code}'
}

function response_body() {
  sed '$d' <<<"$1"
}

function response_status() {
  tail -n 1 <<<"$1"
}

function ensure_process_group() {
  local token="$1"
  local result status body payload

  result=$(curl_with_status GET "${BACKEND_BASE_URL}/v1.0/process-groups/${modified_process_group_identifier}" "$token")
  status=$(response_status "$result")
  body=$(response_body "$result")
  if [[ "$status" == "200" ]]; then
    return
  fi
  if [[ "$status" != "400" || "$body" != *"process_group_cannot_be_found"* ]]; then
    echo >&2 "ERROR: Could not check process group ${process_group_identifier}. result was ${body}"
    exit 1
  fi

  payload=$(jq -nc \
    --arg id "$process_group_identifier" \
    --arg display_name "$process_group_identifier" \
    '{id: $id, display_name: $display_name, description: "Temporary group for message catch race testing", display_order: 0, admin: false}')
  result=$(curl_with_status POST "${BACKEND_BASE_URL}/v1.0/process-groups" "$token" -H "Content-Type: application/json" --data "$payload")
  status=$(response_status "$result")
  body=$(response_body "$result")
  if [[ "$status" != "201" && ! ("$status" == "400" && "$body" == *"already_exists"*) ]]; then
    echo >&2 "ERROR: Could not create process group ${process_group_identifier}. result was ${body}"
    exit 1
  fi
}

function ensure_process_model() {
  local token="$1"
  local result status body payload

  result=$(curl_with_status GET "${BACKEND_BASE_URL}/v1.0/process-models/${modified_process_model_identifier}" "$token")
  status=$(response_status "$result")
  body=$(response_body "$result")
  if [[ "$status" == "200" ]]; then
    return
  fi
  if [[ "$status" != "400" || "$body" != *"process_model_cannot_be_found"* ]]; then
    echo >&2 "ERROR: Could not check process model ${process_model_identifier}. result was ${body}"
    exit 1
  fi

  payload=$(jq -nc \
    --arg id "$process_model_identifier" \
    --arg display_name "${process_model_identifier##*/}" \
    '{id: $id, display_name: $display_name, description: "Reproducer for publish-before-subscribe message loss.", fault_or_suspend_on_exception: "fault", exception_notification_addresses: []}')
  result=$(curl_with_status POST "${BACKEND_BASE_URL}/v1.0/process-models/${modified_process_group_identifier}" "$token" -H "Content-Type: application/json" --data "$payload")
  status=$(response_status "$result")
  body=$(response_body "$result")
  if [[ "$status" != "201" && ! ("$status" == "400" && "$body" == *"already_exists"*) ]]; then
    echo >&2 "ERROR: Could not create process model ${process_model_identifier}. result was ${body}"
    exit 1
  fi
}

function install_embedded_process_model() {
  local token="$1"
  local result status body payload

  ensure_process_group "$token"
  ensure_process_model "$token"

  tmp_bpmn_file=$(mktemp)
  write_embedded_bpmn "$tmp_bpmn_file"

  result=$(curl_with_status PUT "${BACKEND_BASE_URL}/v1.0/process-models/${modified_process_model_identifier}/files/${primary_file_name}" "$token" -F "file=@${tmp_bpmn_file};filename=${primary_file_name};type=text/xml")
  status=$(response_status "$result")
  body=$(response_body "$result")
  if [[ "$status" != "200" ]]; then
    echo >&2 "ERROR: Could not upload embedded BPMN. result was ${body}"
    exit 1
  fi

  payload=$(jq -nc \
    --arg primary_file_name "$primary_file_name" \
    --arg primary_process_id "$primary_process_id" \
    --arg display_name "${process_model_identifier##*/}" \
    '{primary_file_name: $primary_file_name, primary_process_id: $primary_process_id, display_name: $display_name, description: "Reproducer for publish-before-subscribe message loss.", fault_or_suspend_on_exception: "fault", exception_notification_addresses: []}')
  result=$(curl_with_status PUT "${BACKEND_BASE_URL}/v1.0/process-models/${modified_process_model_identifier}" "$token" -H "Content-Type: application/json" --data "$payload")
  status=$(response_status "$result")
  body=$(response_body "$result")
  if [[ "$status" != "200" ]]; then
    echo >&2 "ERROR: Could not set primary BPMN. result was ${body}"
    exit 1
  fi
}

function post_json() {
  local url="$1"
  local token="$2"
  local body="$3"
  curl --silent --show-error -X POST "$url" -H "Authorization: Bearer ${token}" -H "Content-Type: application/json" --data "$body"
}

function search_messages() {
  local token="$1"
  local body="$2"
  curl --silent --show-error -X POST "${BACKEND_BASE_URL}/v1.0/messages" -H "Authorization: Bearer ${token}" -H "Content-Type: application/json" --data "$body"
}

function process_instance_status() {
  local token="$1"
  curl --silent --show-error "${BACKEND_BASE_URL}/v1.0/process-instances/${modified_process_model_identifier}/${process_instance_id}" -H "Authorization: Bearer ${token}" | jq -r '.status'
}

access_token=$(uv run python "${script_dir}/get_token" "$username" "$password" "$realm_name")
curl --silent -X POST "${BACKEND_BASE_URL}/v1.0/login_with_access_token?authentication_identifier=default" -H "Authorization: Bearer $access_token" >/dev/null
install_embedded_process_model "$access_token"

create_result=$(curl --silent --show-error -X POST "${BACKEND_BASE_URL}/v1.0/process-instances/${modified_process_model_identifier}" -H "Authorization: Bearer $access_token")
process_instance_id=$(jq -r '.id' <<<"$create_result")
if ! grep -qE '^[0-9]+$' <<<"$process_instance_id"; then
  echo >&2 "ERROR: Did not receive valid process instance id when instantiating process model. result was ${create_result}"
  exit 1
fi

run_result=$(curl --silent --show-error -X POST "${BACKEND_BASE_URL}/v1.0/process-instances/${modified_process_model_identifier}/${process_instance_id}/run?execution_mode=synchronous" -H "Authorization: Bearer $access_token")
echo "process_instance=${process_instance_id}"
echo "$run_result" | jq -c .

progress_result=$(curl --silent --show-error "${BACKEND_BASE_URL}/v1.0/tasks/progress/${process_instance_id}" -H "Authorization: Bearer $access_token")
task=$(jq '.task' <<<"$progress_result")
task_type=$(jq -r '.type' <<<"$task")
task_state=$(jq -r '.state' <<<"$task")
task_guid=$(jq -r '.id' <<<"$task")

if [[ "$task_type" != "ManualTask" || "$task_state" != "READY" ]]; then
  echo >&2 "ERROR: Expected to land on a READY ManualTask, got: ${task}"
  exit 1
fi

echo "manual_task=${task_guid}"
echo "publishing_early_message=${message_name} race_id=${race_id}"
early_result=$(curl_with_status POST "${BACKEND_BASE_URL}/v1.0/messages/${message_name}?time_to_live_in_seconds=60&message_instance_uuid=${message_instance_uuid}" "$access_token" -H "Content-Type: application/json" --data "{\"race_id\":\"${race_id}\"}")
early_status=$(response_status "$early_result")
early_response=$(response_body "$early_result")
echo "$early_response" | jq -c .
if [[ "$early_status" != "202" ]]; then
  echo >&2 "ERROR: Expected early publish to return HTTP 202 while no receiver is waiting. status=${early_status} body=${early_response}"
  exit 1
fi
buffered_message_status=$(jq -r '.message_instance.status // empty' <<<"$early_response")
buffered_message_id=$(jq -r '.message_instance.id // empty' <<<"$early_response")
if [[ "$buffered_message_status" != "ready" ]]; then
  echo >&2 "ERROR: Expected early publish to be buffered as a ready message."
  exit 1
fi
if ! grep -qE '^[0-9]+$' <<<"$buffered_message_id"; then
  echo >&2 "ERROR: Expected early publish response to include a buffered message id. body=${early_response}"
  exit 1
fi

cached_send_query=$(jq -nc --arg name "$message_name" '{name: $name, message_type: ["send"], status: ["ready"]}')
cached_send_response=$(search_messages "$access_token" "$cached_send_query")
cached_send=$(jq -c --arg uuid "$message_instance_uuid" '.results[] | select(.message_instance_uuid == $uuid)' <<<"$cached_send_response")
if [[ -z "$cached_send" ]]; then
  echo >&2 "ERROR: Expected to find cached ready send message with message_instance_uuid=${message_instance_uuid}. search result was ${cached_send_response}"
  exit 1
fi
cached_send_id=$(jq -r '.id' <<<"$cached_send")
if [[ "$cached_send_id" != "$buffered_message_id" ]]; then
  echo >&2 "ERROR: Cached send id ${cached_send_id} did not match publish response id ${buffered_message_id}."
  exit 1
fi
echo "cached_message=${cached_send_id} status=ready expires_at=$(jq -r '.expires_at_in_seconds // empty' <<<"$cached_send")"

pre_complete_process_messages=$(curl --silent --show-error "${BACKEND_BASE_URL}/v1.0/messages?process_instance_id=${process_instance_id}" -H "Authorization: Bearer ${access_token}")
pre_complete_receive_count=$(jq --arg name "$message_name" '[.results[] | select(.name == $name and .message_type == "receive")] | length' <<<"$pre_complete_process_messages")
if [[ "$pre_complete_receive_count" != "0" ]]; then
  echo >&2 "ERROR: Expected no receive message before completing the manual task. process messages were ${pre_complete_process_messages}"
  exit 1
fi
echo "verified_cached_message_waiting=true"

echo "completing_manual_task=${task_guid}"
complete_result=$(curl_with_status PUT "${BACKEND_BASE_URL}/v1.0/tasks/${process_instance_id}/${task_guid}?execution_mode=synchronous" "$access_token" -H "Content-Type: application/json" --data '{}')
complete_status=$(response_status "$complete_result")
complete_response=$(response_body "$complete_result")
echo "$complete_response" | jq -c .
if [[ "$complete_status" != "200" ]]; then
  echo >&2 "ERROR: Expected manual task completion to return HTTP 200. status=${complete_status} body=${complete_response}"
  exit 1
fi

final_status=$(process_instance_status "$access_token")
if [[ "$final_status" != "complete" ]]; then
  echo >&2 "ERROR: Expected process instance ${process_instance_id} to complete after the cached message was consumed. status=${final_status}"
  exit 1
fi

completed_message_query=$(jq -nc --arg name "$message_name" '{name: $name, message_type: ["send", "receive"], status: ["completed"]}')
completed_message_response=$(search_messages "$access_token" "$completed_message_query")
completed_send=$(jq -c --arg uuid "$message_instance_uuid" '.results[] | select(.message_instance_uuid == $uuid and .message_type == "send")' <<<"$completed_message_response")
if [[ -z "$completed_send" ]]; then
  echo >&2 "ERROR: Expected cached send message ${cached_send_id} to be completed after manual task completion. search result was ${completed_message_response}"
  exit 1
fi
completed_send_id=$(jq -r '.id' <<<"$completed_send")
completed_send_counterpart_id=$(jq -r '.counterpart_id // empty' <<<"$completed_send")
if [[ "$completed_send_id" != "$cached_send_id" || ! "$completed_send_counterpart_id" =~ ^[0-9]+$ ]]; then
  echo >&2 "ERROR: Completed send message was not counterpart-linked as expected: ${completed_send}"
  exit 1
fi

completed_receive=$(jq -c --arg process_instance_id "$process_instance_id" --arg counterpart_id "$completed_send_id" '.results[] | select((.process_instance_id | tostring) == $process_instance_id and (.counterpart_id | tostring) == $counterpart_id and .message_type == "receive")' <<<"$completed_message_response")
if [[ -z "$completed_receive" ]]; then
  echo >&2 "ERROR: Expected a completed receive message on process_instance=${process_instance_id} linked to send=${completed_send_id}. search result was ${completed_message_response}"
  exit 1
fi
completed_receive_id=$(jq -r '.id' <<<"$completed_receive")
if [[ "$completed_receive_id" != "$completed_send_counterpart_id" ]]; then
  echo >&2 "ERROR: Send counterpart ${completed_send_counterpart_id} did not match receive id ${completed_receive_id}."
  exit 1
fi

echo "repro_complete"
echo "ttl_cache_verified=true"
echo "process_instance=${process_instance_id} status=${final_status}"
echo "send_message=${completed_send_id} receive_message=${completed_receive_id} status=completed"
