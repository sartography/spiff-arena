<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:spiffworkflow="http://spiffworkflow.org/bpmn/schema/1.0/core" id="Definitions_task_definition_search_main" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Task_Definition_Search_Main" name="Task Definition Search Main" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_start_main_anchor</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_start_main_anchor" sourceRef="StartEvent_1" targetRef="main_anchor" />
    <bpmn:manualTask id="main_anchor" name="Main Anchor">
      <bpmn:extensionElements>
        <spiffworkflow:properties>
          <spiffworkflow:property name="civitos.slotBefore" value="before_main_anchor" />
          <spiffworkflow:property name="civitos.slotLabel" value="Before main anchor" />
        </spiffworkflow:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_start_main_anchor</bpmn:incoming>
      <bpmn:outgoing>Flow_main_anchor_call</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:sequenceFlow id="Flow_main_anchor_call" sourceRef="main_anchor" targetRef="call_nested_process" />
    <bpmn:callActivity id="call_nested_process" name="Call Nested Process" calledElement="Task_Definition_Search_Nested">
      <bpmn:incoming>Flow_main_anchor_call</bpmn:incoming>
      <bpmn:outgoing>Flow_call_end</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:sequenceFlow id="Flow_call_end" sourceRef="call_nested_process" targetRef="EndEvent_1" />
    <bpmn:endEvent id="EndEvent_1">
      <bpmn:incoming>Flow_call_end</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Task_Definition_Search_Main">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="160" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="main_anchor_di" bpmnElement="main_anchor">
        <dc:Bounds x="250" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="call_nested_process_di" bpmnElement="call_nested_process">
        <dc:Bounds x="410" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="570" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_start_main_anchor_di" bpmnElement="Flow_start_main_anchor">
        <di:waypoint x="196" y="118" />
        <di:waypoint x="250" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_main_anchor_call_di" bpmnElement="Flow_main_anchor_call">
        <di:waypoint x="350" y="118" />
        <di:waypoint x="410" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_call_end_di" bpmnElement="Flow_call_end">
        <di:waypoint x="510" y="118" />
        <di:waypoint x="570" y="118" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
