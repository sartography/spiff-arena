<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:spiffworkflow="http://spiffworkflow.org/bpmn/schema/1.0/core" id="Definitions_task_definition_search_nested" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Task_Definition_Search_Nested" name="Task Definition Search Nested" isExecutable="true">
    <bpmn:startEvent id="NestedStartEvent_1">
      <bpmn:outgoing>Flow_nested_start_anchor</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_nested_start_anchor" sourceRef="NestedStartEvent_1" targetRef="nested_anchor" />
    <bpmn:manualTask id="nested_anchor" name="Nested Anchor">
      <bpmn:extensionElements>
        <spiffworkflow:properties>
          <spiffworkflow:property name="civitos.slotBefore" value="before_nested_anchor" />
          <spiffworkflow:property name="civitos.slotLabel" value="Before nested anchor" />
        </spiffworkflow:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_nested_start_anchor</bpmn:incoming>
      <bpmn:outgoing>Flow_nested_anchor_end</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:sequenceFlow id="Flow_nested_anchor_end" sourceRef="nested_anchor" targetRef="NestedEndEvent_1" />
    <bpmn:endEvent id="NestedEndEvent_1">
      <bpmn:incoming>Flow_nested_anchor_end</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Task_Definition_Search_Nested">
      <bpmndi:BPMNShape id="NestedStartEvent_1_di" bpmnElement="NestedStartEvent_1">
        <dc:Bounds x="160" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="nested_anchor_di" bpmnElement="nested_anchor">
        <dc:Bounds x="250" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="NestedEndEvent_1_di" bpmnElement="NestedEndEvent_1">
        <dc:Bounds x="410" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_nested_start_anchor_di" bpmnElement="Flow_nested_start_anchor">
        <di:waypoint x="196" y="118" />
        <di:waypoint x="250" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_nested_anchor_end_di" bpmnElement="Flow_nested_anchor_end">
        <di:waypoint x="350" y="118" />
        <di:waypoint x="410" y="118" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
