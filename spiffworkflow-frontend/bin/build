#!/usr/bin/env bash

function error_handler() {
  >&2 echo "Exited with BAD EXIT CODE '${2}' in ${0} script at line: ${1}."
  exit "$2"
}
trap 'error_handler ${LINENO} $?' ERR
set -o errtrace -o errexit -o nounset -o pipefail

if [[ -f "version_info.json" ]]; then
  version_info=$(cat version_info.json)
  export VITE_VERSION_INFO="$version_info"
fi

npm run build

mkdir -p dist
node <<'NODE' >dist/version-info
const versionInfo = JSON.parse(process.env.VITE_VERSION_INFO || '{}');
const publicVersionInfo = {};

const version = versionInfo['org.opencontainers.image.version'];
const revision = versionInfo['org.opencontainers.image.revision'];
const created = versionInfo['org.opencontainers.image.created'];

if (version) {
  publicVersionInfo.version = version;
}
if (revision) {
  publicVersionInfo.revision = revision;
}
if (created) {
  publicVersionInfo.created = created;
}

process.stdout.write(`${JSON.stringify(publicVersionInfo, null, 2)}\n`);
NODE
