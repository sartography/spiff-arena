#!/usr/bin/env bash

function error_handler() {
  >&2 echo "Exited with BAD EXIT CODE '${2}' in ${0} script at line: ${1}."
  exit "$2"
}
trap 'error_handler ${LINENO} $?' ERR
set -o errtrace -o errexit -o nounset -o pipefail

script_dir="$( cd -- "$(dirname "$0")" >/dev/null 2>&1 ; pwd -P )"
frontend_dir="${script_dir}/.."
bpmn_js_dir="${frontend_dir}/../../bpmn-js-spiffworkflow"

if [[ ! -d "$bpmn_js_dir" ]]; then
  >&2 echo "ERROR: Could not find a bpmn-js-spiffworkflow dir at '$bpmn_js_dir'. Please clone it from https://github.com/sartography/bpmn-js-spiffworkflow.git."
  exit 1
fi

if [[ ! -d "${frontend_dir}/node_modules" ]]; then
  npm --prefix "$frontend_dir" i
fi

if [[ ! -d "${bpmn_js_dir}/node_modules" ]]; then
  npm --prefix "$bpmn_js_dir" i
fi

# Keep the linked package's own runtime deps, but remove peer/runtime copies
# that must resolve from the consuming app to avoid duplicate React/Preact/BPMN stacks.
rm -rf \
  "${bpmn_js_dir}/node_modules/@bpmn-io" \
  "${bpmn_js_dir}/node_modules/bpmn-js" \
  "${bpmn_js_dir}/node_modules/bpmn-js-properties-panel" \
  "${bpmn_js_dir}/node_modules/diagram-js" \
  "${bpmn_js_dir}/node_modules/react" \
  "${bpmn_js_dir}/node_modules/react-dom"
if [[ ! -d "${bpmn_js_dir}/node_modules/inherits" ]]; then
  npm --prefix "$bpmn_js_dir" i
fi

pushd "$frontend_dir"
npm link "$bpmn_js_dir"
popd
